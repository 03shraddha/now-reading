rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // submissions: anyone can read, no client writes allowed
    match /submissions/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // rate_limits and used_nonces: backend-only (Admin SDK bypasses rules)
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    match /used_nonces/{docId} {
      allow read, write: if false;
    }

    // deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
